# FieldStation42 distributed node setup example.
#
# Copy this file and edit values before running scripts, or export the
# variables in your shell. The setup scripts also prompt when values are
# missing.

# Common
FS42_DIR="$HOME/FieldStation42"
FS42_USER="$USER"

# Headend identity
HEADEND_HOST="10.0.0.99"
HEADEND_LAN_CIDR="10.0.0.0/24"

# Headend paths
HEADEND_FS42_DIR="/home/cableguy/FieldStation42"
HEADEND_MEDIA_ROOT="/media/FS42DB/fs42"
HEADEND_CONFS_DIR="/home/cableguy/FieldStation42/confs"
HEADEND_RUNTIME_DIR="/home/cableguy/FieldStation42/runtime"

# Node mount paths.
# setup-node.sh can detect the NFS source paths with showmount after you enter
# HEADEND_HOST. These values are still useful when showmount is unavailable or
# you want to override the detected paths.
# Use the same media path as the headend when possible because catalog rows may
# contain host realpaths such as /media/FS42DB/fs42/catalog/...
NODE_MEDIA_MOUNT="/media/FS42DB/fs42"
NODE_CONFS_MOUNT="/mnt/fs42-headend-confs"
NODE_RUNTIME_MOUNT="/mnt/fs42-headend-runtime"

# NFS exports as seen from the node.
MEDIA_NFS_SOURCE="10.0.0.99:/media/FS42DB/fs42"
CONFS_NFS_SOURCE="10.0.0.99:/home/cableguy/FieldStation42/confs"
RUNTIME_NFS_SOURCE="10.0.0.99:/home/cableguy/FieldStation42/runtime"

# Player service defaults
DISPLAY_VALUE=":0"
START_CHANNEL=""
